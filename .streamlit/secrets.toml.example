# Copy this file to ".streamlit/secrets.toml" and fill in your values.
# On Streamlit Community Cloud, paste this same content into
# App settings -> Secrets (do NOT commit the real file to GitHub).

# ---- Shared database (Supabase) ----
# Get these from your Supabase project: Settings -> API
[supabase]
url = "https://YOUR-PROJECT.supabase.co"
key = "YOUR-SERVICE-ROLE-KEY"   # use the service_role secret key

# ---- Logins (one block per person) ----
[[auth.users]]
username = "darshan"
name = "Darshan"
password = "change-this-password"

[[auth.users]]
username = "kunal"
name = "Kunal"
password = "change-this-password"
